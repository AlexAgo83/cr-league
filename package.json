{
  "name": "cr-league",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @cr-league/api",
    "dev:web": "npm run dev -w @cr-league/web",
    "build": "npm run build -w @cr-league/shared && npm run build -w @cr-league/api && npm run build -w @cr-league/web",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "playtest:seed": "tsx scripts/seed-playtest-league.ts",
    "db:studio": "prisma studio",
    "smoke:league": "tsx scripts/smoke-league-flow.ts",
    "balance:sim": "tsx scripts/balance-simulations.ts",
    "audit:circuits": "node scripts/audit-circuits.mjs",
    "logics:validate": "logics-manager lint --require-status && logics-manager audit --group-by-doc"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@grifhinz/logics-manager": "^2.19.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jsdom": "^27.2.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.8"
  }
}
