DATABASE_URL="postgresql://user:password@localhost:5432/cr_league?schema=cr_league"
API_HOST="127.0.0.1"
API_PORT="4874"
WEB_ORIGIN="http://localhost:4873"
ADMIN_EMAILS="admin@example.test"
ADMIN_TOKEN="change-me"
# Transactional email (profile recovery, req_061). Leave unset to run the mailer as a no-op.
# Gmail: use a dedicated account with 2-Step Verification and a 16-char App Password (spaces removed) as SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-address@gmail.com"
SMTP_PASS="your-gmail-app-password"
MAIL_FROM="CR League <your-address@gmail.com>"
