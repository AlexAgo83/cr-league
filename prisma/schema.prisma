generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model League {
  id                    String    @id @default(cuid())
  name                  String
  code                  String    @unique
  status                String    @default("active")
  cadence               String    @default("manual")
  maxPlayers            Int       @default(8)
  fillWithBots          Boolean   @default(true)
  qualifyingAttemptLimit Int       @default(3)
  maxGrandPrixPerSeason Int       @default(6)
  ownerTeamId           String?
  preparationDeadlineAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  teams       Team[]
  grandPrixes GrandPrix[]

  @@map("leagues")
}

model Profile {
  id                  String    @id @default(cuid())
  email               String    @unique
  recoveryCodeHash    String
  recoveryEmailSentAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  teams Team[]

  @@map("profiles")
}

model Team {
  id        String   @id @default(cuid())
  leagueId  String
  profileId String?
  name      String
  kind      String   @default("human")
  claimCode String?  @unique
  credits   Int      @default(0)
  points    Int      @default(0)
  cards     Json     @default("[]")
  livery    Json     @default("{\"primary\":\"#16c784\",\"secondary\":\"#38bdf8\"}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  league    League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  decisions RaceDecision[]

  @@unique([leagueId, name])
  @@index([profileId])
  @@map("teams")
}

model GrandPrix {
  id             String   @id @default(cuid())
  leagueId       String
  season         Int      @default(1)
  name           String
  round          Int      @default(1)
  seed           String
  primaryTrait   String
  secondaryTrait String
  forecast       Json
  qualifyingRuns Json     @default("[]")
  status         String   @default("briefing")
  result         Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  league    League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  decisions RaceDecision[]

  @@unique([leagueId, season, round])
  @@map("grand_prixes")
}

model RaceDecision {
  id           String   @id @default(cuid())
  grandPrixId  String
  teamId       String
  approach     String
  preparation  String
  pitStrategy  String   @default("standard")
  cardId       String?
  rivalTeamId  String?
  submittedAt  DateTime @default(now())

  grandPrix GrandPrix @relation(fields: [grandPrixId], references: [id], onDelete: Cascade)
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([grandPrixId, teamId])
  @@map("race_decisions")
}
