{
  "name": "cr-league",
  "version": "0.3.22",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf apps/api/dist apps/web/dist packages/shared/dist apps/api/tsconfig.tsbuildinfo apps/web/tsconfig.tsbuildinfo packages/shared/tsconfig.tsbuildinfo",
    "dev": "node scripts/dev-local.mjs",
    "dev:stop": "node scripts/stop-dev.mjs",
    "dev:api": "npm run dev -w @cr-league/api",
    "dev:web": "npm run dev -w @cr-league/web",
    "build": "npm run build -w @cr-league/shared && npm run build -w @cr-league/api && npm run build -w @cr-league/web",
    "typecheck": "tsc -b && tsc -p scripts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "playtest:seed": "tsx scripts/seed-playtest-league.ts",
    "db:studio": "prisma studio",
    "smoke:league": "tsx scripts/smoke-league-flow.ts",
    "playtest:simulate": "tsx scripts/simulate-playtest.ts",
    "playtest:ai": "tsx scripts/ai-playtest.ts",
    "replay:validate": "tsx scripts/validate-replay-trace.ts",
    "balance:sim": "tsx scripts/balance-simulations.ts",
    "generate:circuit": "node scripts/generate-circuit.mjs",
    "audit:circuits": "node scripts/audit-circuits.mjs",
    "review:circuits:water": "node scripts/review-circuit-water.mjs",
    "logics:validate": "logics-manager lint --require-status && logics-manager audit --group-by-doc"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@grifhinz/logics-manager": "^2.19.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0",
    "jsdom": "^27.2.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.8"
  }
}
